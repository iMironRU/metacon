{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/iMironRU/metacon/schema/mechanism-card.schema.json",
  "title": "MetaCon Mechanism Card",
  "description": "Карточка механизма. Ключи — латиницей (контракт/код), значения предметной области — на русском. Поле model — типизированное объединение по kind (диспетчер). См. docs/CONCEPT.md §6, §8.",
  "type": "object",
  "required": ["id", "kind", "section", "skill", "requires_context", "contributes", "traps", "tolerance", "levels", "model"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "kind": { "enum": ["РН", "РС", "РБ", "РР", "БП", "Форма"] },
    "section": { "enum": ["оперативный", "бухгалтерский", "расчёт", "бизнес-процессы", "формы"] },
    "skill": { "type": "string" },
    "requires_context": { "type": "array", "items": { "type": "string" } },
    "contributes": {
      "type": "object", "required": ["objects", "changes"], "additionalProperties": false,
      "properties": {
        "objects": { "type": "array", "items": { "type": "string" } },
        "changes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "traps": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["lure", "correct", "why"], "additionalProperties": false,
        "properties": { "lure": { "type": "string" }, "correct": { "type": "string" }, "why": { "type": "string" } }
      }
    },
    "tolerance": {
      "type": "object",
      "description": "Спека допусков: обязательное / допустимое / дисквалификаторы. По ней грейдятся уровни 1-2.",
      "required": ["required_objects", "required_structure", "allowed", "disqualifiers"], "additionalProperties": false,
      "properties": {
        "required_objects": { "type": "array", "items": {
          "type": "object", "required": ["role", "object_kind"], "additionalProperties": false,
          "properties": { "role": { "type": "string" }, "object_kind": { "$ref": "#/$defs/objectKind" } }
        } },
        "required_structure": { "type": "array", "items": {
          "type": "object", "required": ["object", "dimensions", "resources"], "additionalProperties": false,
          "properties": { "object": { "type": "string" }, "dimensions": { "type": "array", "items": { "type": "string" } }, "resources": { "type": "array", "items": { "type": "string" } } }
        } },
        "allowed": { "type": "array", "items": { "type": "string" } },
        "disqualifiers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "levels": {
      "type": "object", "required": ["1", "2"], "additionalProperties": false,
      "properties": { "1": { "$ref": "#/$defs/level" }, "2": { "$ref": "#/$defs/level" }, "3": { "$ref": "#/$defs/level" } }
    },
    "render": {
      "type": "object", "additionalProperties": false,
      "description": "Пулы для рандомизации поверхности. Контент — наш, не из книги.",
      "properties": {
        "nomenclature_pool": { "type": "array", "items": { "type": "string" } },
        "period_pool": { "type": "array", "items": { "type": "string" } },
        "qty_range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
        "price_range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
        "scaffold_template": { "type": "string" }
      }
    },
    "model": {
      "description": "Единственный источник истины. Форма тела зависит от kind.",
      "oneOf": [ { "$ref": "#/$defs/modelRN" }, { "$ref": "#/$defs/modelStub" } ]
    }
  },
  "$defs": {
    "objectKind": {
      "enum": ["Справочник", "Документ", "Перечисление", "РегистрНакопления", "РегистрСведений", "РегистрБухгалтерии", "РегистрРасчёта", "ПланСчетов", "ПланВидовХарактеристик", "ПланВидовРасчёта", "БизнесПроцесс", "Задача", "Форма"]
    },
    "level": {
      "type": "object", "required": ["projection", "grade"], "additionalProperties": false,
      "properties": {
        "projection": { "type": "string" },
        "grade": { "enum": ["точное_множество", "обязательное_ядро", "эталон_поведение"] },
        "modes": { "type": "array", "items": { "enum": ["декларатив", "код", "поведение"] } }
      }
    },
    "field": {
      "type": "object", "required": ["name"], "additionalProperties": false,
      "properties": { "name": { "type": "string" }, "type": { "type": "string" }, "role": { "enum": ["измерение", "ресурс", "реквизит"] } }
    },
    "objectDef": {
      "type": "object", "required": ["name", "object_kind"], "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "object_kind": { "$ref": "#/$defs/objectKind" },
        "subtype": { "type": "string" },
        "values": { "type": "array", "items": { "type": "string" } },
        "fields": { "type": "array", "items": { "$ref": "#/$defs/field" } },
        "tabular_sections": { "type": "array", "items": {
          "type": "object", "required": ["name", "fields"],
          "properties": { "name": { "type": "string" }, "fields": { "type": "array", "items": { "type": "string" } } }
        } }
      }
    },
    "modelRN": {
      "type": "object", "required": ["kind", "objects", "register", "movements"], "additionalProperties": false,
      "properties": {
        "kind": { "const": "РН" },
        "partners": { "type": "array", "items": { "$ref": "#/$defs/objectDef" } },
        "objects": { "type": "array", "items": { "$ref": "#/$defs/objectDef" } },
        "register": {
          "type": "object", "required": ["name", "subtype", "dimensions", "resources"], "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "subtype": { "enum": ["остатки", "обороты", "остатки_обороты"] },
            "dimensions": { "type": "array", "items": { "$ref": "#/$defs/field" } },
            "resources": { "type": "array", "items": { "$ref": "#/$defs/field" } },
            "attributes": { "type": "array", "items": { "$ref": "#/$defs/field" } }
          }
        },
        "movements": { "type": "array", "items": {
          "type": "object", "required": ["document", "records"], "additionalProperties": false,
          "properties": {
            "document": { "type": "string" },
            "records": { "type": "array", "items": {
              "type": "object", "required": ["kind"], "additionalProperties": false,
              "properties": { "kind": { "enum": ["Приход", "Расход"] }, "resources": { "type": "object" }, "algorithm_id": { "type": "string" } }
            } }
          }
        } }
      }
    },
    "modelStub": {
      "type": "object", "required": ["kind"],
      "description": "Заглушка для kind ∈ {РС, РБ, РР, БП, Форма}. Тело дозревает отдельно (CONCEPT §8).",
      "properties": { "kind": { "enum": ["РС", "РБ", "РР", "БП", "Форма"] } }
    }
  }
}
